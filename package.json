{
  "name": "portfolio-website",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:smoke": "vitest run --testNamePattern=smoke",
    "deploy": "astro build && wrangler pages deploy dist --project-name=arthurpfz-portfolio"
  },
  "dependencies": {
    "astro": "^6.0.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "happy-dom": "^20.8.4",
    "rehype-plugin-image-native-lazy-loading": "^1.2.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.73.0"
  }
}
