---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Feed' },
  { href: '/builds', label: 'Builds' },
  { href: '/experience', label: 'About' },
  { href: 'https://www.linkedin.com/in/apfalzgraf/', label: 'LinkedIn', external: true },
  { href: 'https://github.com/Arthurpfz', label: 'GitHub', external: true },
  { href: 'https://x.com/arthurpfz', label: 'X', external: true },
];

function isActive(path: string) {
  return currentPath === path || currentPath.startsWith(path + '/');
}
---

<a href="#main-content" class="skip-link">Skip to main content</a>

<nav class="site-nav" role="navigation" aria-label="Site navigation">
  <a href="/" class="nav-link site-name">arthurpfz.com</a>
  <div class="nav-links">
    {navLinks.map(link => (
      <a
        href={link.href}
        class:list={['nav-link', { active: !link.external && isActive(link.href) }]}
        aria-current={!link.external && isActive(link.href) ? 'page' : undefined}
        target={link.external ? '_blank' : undefined}
        rel={link.external ? 'noopener noreferrer' : undefined}
      >
        {link.label}{link.external && ' ↗'}
      </a>
    ))}
  </div>
</nav>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
    z-index: 9999;
    padding: 4px 8px;
    background: var(--color-bg);
    color: var(--color-primary);
    text-decoration: none;
  }

  .skip-link:focus {
    position: static;
    width: auto;
    height: auto;
    overflow: visible;
  }

  @media (max-width: 768px) {
    .nav-links { gap: var(--space-md); }
    .nav-link { font-size: 10px; }
  }
</style>
