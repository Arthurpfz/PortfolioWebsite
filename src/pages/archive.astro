---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const publishedArticles = articles
  .filter(article => !article.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Archive - Arthur Pfalzgraf"
  description="Arthur's PM homework - documenting product work"
>
  <h1>Arthur's PM Homework</h1>

  <p class="intro">
    PMs document everything. Here's my homework — PRDs, retrospectives, and analysis that seemed important at the time.
  </p>

  <section class="articles-section" aria-label="Article archive">
    <h2>Articles</h2>
    <ul class="article-list">
      {publishedArticles.map(article => {
        const slug = article.id.replace(/\.md$/, '');
        return (
        <li class="article-item">
          <h3 class="article-title">
            <a href={`/archive/${slug}`}>{article.data.title}</a>
          </h3>
          <div class="article-meta">
            <time datetime={article.data.date.toISOString()}>
              {article.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {article.data.tags && article.data.tags.length > 0 && (
              <span class="article-tags">
                {article.data.tags.join(', ')}
              </span>
            )}
          </div>
          <p class="article-description">{article.data.description}</p>
        </li>
      )}
      )}
    </ul>
  </section>
</BaseLayout>

<style>
  h1 {
    font-size: var(--text-h1-size);
    line-height: var(--text-h1-line-height);
    font-weight: var(--text-h1-weight);
    letter-spacing: var(--text-h1-spacing);
    margin-bottom: var(--space-content-lg);
  }

  .intro {
    font-size: var(--text-body-size);
    line-height: var(--text-body-line-height);
    color: var(--color-foreground-secondary);
    margin-bottom: var(--space-section-md);
  }

  .articles-section {
    margin-top: var(--space-section-lg);
  }

  h2 {
    font-size: var(--text-h2-size);
    line-height: var(--text-h2-line-height);
    font-weight: var(--text-h2-weight);
    letter-spacing: var(--text-h2-spacing);
    margin-bottom: var(--space-content-md);
  }

  .article-list {
    list-style: none;
    padding: 0;
    margin: var(--space-content-md) 0;
  }

  .article-item {
    margin-bottom: var(--space-content-xl);
    padding-bottom: var(--space-content-lg);
    border-bottom: 1px solid var(--color-border-primary);
  }

  .article-item:last-child {
    border-bottom: none;
  }

  .article-title {
    font-size: var(--text-h3-size);
    line-height: var(--text-h3-line-height);
    font-weight: var(--text-h3-weight);
    letter-spacing: var(--text-h3-spacing);
    margin-bottom: var(--space-content-sm);
    color: var(--color-foreground-primary);
  }

  .article-title a {
    color: var(--color-foreground-primary);
    text-decoration: none;
  }

  .article-title a:hover {
    text-decoration: underline;
  }

  .article-meta {
    display: flex;
    gap: var(--space-content-md);
    font-size: var(--text-caption-size);
    color: var(--color-foreground-secondary);
    margin-bottom: var(--space-content-sm);
  }

  .article-tags {
    font-style: italic;
  }

  .article-description {
    font-size: var(--text-body-size);
    line-height: var(--text-body-line-height);
    color: var(--color-foreground-secondary);
  }
</style>
