---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const articles = await getCollection('articles');
  const publishedArticles = articles.filter(article => !article.data.draft);

  return publishedArticles.map(entry => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  title={`${entry.data.title} - Arthur Pfalzgraf`}
  description={entry.data.description}
>
  <article class="article">
    <header class="article-header">
      <h1 class="article-title">{entry.data.title}</h1>
      <div class="article-meta">
        <time datetime={entry.data.date.toISOString()}>
          {entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {entry.data.tags && entry.data.tags.length > 0 && (
          <span class="article-tags">
            {entry.data.tags.join(', ')}
          </span>
        )}
      </div>
    </header>
    <div class="article-content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    max-width: 70ch;
    margin: 0 auto;
  }

  .article-header {
    margin-bottom: var(--space-content-xl);
  }

  .article-title {
    font-size: var(--text-h1-size);
    line-height: var(--text-h1-line-height);
    font-weight: var(--text-h1-weight);
    letter-spacing: var(--text-h1-spacing);
    margin-bottom: var(--space-content-md);
    color: var(--color-foreground-primary);
  }

  .article-meta {
    display: flex;
    gap: var(--space-content-md);
    font-size: var(--text-caption-size);
    color: var(--color-foreground-secondary);
    margin-bottom: var(--space-content-sm);
  }

  .article-tags {
    font-style: italic;
  }

  .article-content {
    font-size: var(--text-body-size);
    line-height: var(--text-body-line-height);
    color: var(--color-foreground-primary);
  }

  /* Prose styling for markdown content */
  .article-content :global(h1),
  .article-content :global(h2),
  .article-content :global(h3),
  .article-content :global(h4),
  .article-content :global(h5),
  .article-content :global(h6) {
    font-weight: var(--text-h2-weight);
    letter-spacing: var(--text-h2-spacing);
    margin-top: var(--space-content-xl);
    margin-bottom: var(--space-content-md);
    color: var(--color-foreground-primary);
  }

  .article-content :global(h1) {
    font-size: var(--text-h2-size);
    line-height: var(--text-h2-line-height);
  }

  .article-content :global(h2) {
    font-size: var(--text-h2-size);
    line-height: var(--text-h2-line-height);
  }

  .article-content :global(h3) {
    font-size: var(--text-h3-size);
    line-height: var(--text-h3-line-height);
    font-weight: var(--text-h3-weight);
    letter-spacing: var(--text-h3-spacing);
  }

  .article-content :global(h4),
  .article-content :global(h5),
  .article-content :global(h6) {
    font-size: var(--text-body-size);
    line-height: var(--text-body-line-height);
  }

  .article-content :global(p) {
    margin-bottom: var(--space-content-md);
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: var(--space-content-md);
    padding-left: var(--space-content-lg);
  }

  .article-content :global(li) {
    margin-bottom: var(--space-content-sm);
  }

  .article-content :global(blockquote) {
    border-left: 3px solid var(--color-border-primary);
    padding-left: var(--space-content-md);
    margin: var(--space-content-lg) 0;
    color: var(--color-foreground-secondary);
    font-style: italic;
  }

  .article-content :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: var(--space-content-lg) auto;
    border-radius: 4px;
  }

  .article-content :global(a) {
    color: var(--color-foreground-primary);
    text-decoration: underline;
    text-decoration-color: var(--color-border-primary);
    text-underline-offset: 2px;
  }

  .article-content :global(a:hover) {
    text-decoration-color: var(--color-foreground-primary);
  }

  .article-content :global(code) {
    background-color: var(--color-background-secondary, #f5f5f5);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 0.9em;
    font-family: 'Monaco', 'Courier New', monospace;
  }

  .article-content :global(pre) {
    background-color: var(--color-background-secondary, #f5f5f5);
    padding: var(--space-content-md);
    border-radius: 4px;
    overflow-x: auto;
    margin: var(--space-content-lg) 0;
  }

  .article-content :global(pre code) {
    background-color: transparent;
    padding: 0;
  }
</style>
